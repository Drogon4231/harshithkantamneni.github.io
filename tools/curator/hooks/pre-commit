#!/bin/bash
# Pre-commit hook: runs the full site-quality gate on staged + relevant
# global state. Three audits, in order:
#
#   1. audit_site.py     — future dates, [VERIFY] markers, TODO/FIXME,
#                          forbidden phrases (per tools/curator/forbidden_phrases.txt).
#                          Runs on STAGED files only — pre-existing issues
#                          elsewhere don't block your unrelated commits.
#
#   2. check_links.py    — broken internal links / missing assets / broken
#                          anchor fragments / broken frontmatter imports.
#                          Runs SITE-WIDE — link integrity is a property of
#                          the whole site, not individual staged files.
#
#   3. check_freshness.py — stale content (time-sensitive pages past their
#                           verification interval). Runs SITE-WIDE; STALE
#                           pages block (exit 1), expiring-soon pages warn.
#
# Install once:    bash tools/curator/hooks/install.sh
# Bypass (sparingly): git commit --no-verify

set -euo pipefail

WEBSITE_ROOT="$( git rev-parse --show-toplevel )"
cd "$WEBSITE_ROOT"

# ---------------------------------------------------------------------------
# Audit 1: staged-file content audit
# ---------------------------------------------------------------------------
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
    | grep -E '^src/pages/.*\.(astro|md|js)$' || true)

if [ -n "$STAGED" ]; then
    if ! python3 tools/curator/audit_site.py $STAGED; then
        echo ""
        echo "pre-commit: site audit found issues in your staged changes."
        echo "  - Fix them, then re-stage and re-commit."
        echo "  - Or bypass with: git commit --no-verify  (use sparingly)"
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Audit 2: site-wide link integrity (only if any src/ or public/ files staged)
# ---------------------------------------------------------------------------
STAGED_SITE=$(git diff --cached --name-only --diff-filter=ACMD 2>/dev/null \
    | grep -E '^(src/|public/|astro\.config\.)' || true)

if [ -n "$STAGED_SITE" ]; then
    if ! python3 tools/curator/check_links.py; then
        echo ""
        echo "pre-commit: link integrity audit found broken internal links."
        echo "  - Fix the targets or remove the broken links."
        echo "  - Or bypass with: git commit --no-verify  (use sparingly)"
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Audit 3: site-wide content freshness
# ---------------------------------------------------------------------------
# Always check freshness on commits that touch src/pages/, so stale pages
# can't accumulate silently. Only HARD-stale (overdue) blocks; expiring-soon
# is informational and exits 0.
STAGED_PAGES=$(git diff --cached --name-only --diff-filter=ACMD 2>/dev/null \
    | grep -E '^src/pages/' || true)

if [ -n "$STAGED_PAGES" ]; then
    if ! python3 tools/curator/check_freshness.py --grace-days 14; then
        echo ""
        echo "pre-commit: content freshness audit found stale pages."
        echo "  - Re-verify each stale page, then run:"
        echo "      python3 tools/curator/check_freshness.py --mark-verified <path>"
        echo "  - Or bypass with: git commit --no-verify  (use sparingly)"
        exit 1
    fi
fi

exit 0
