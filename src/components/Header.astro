  <nav>
    <a href="/harshithkantamneni.github.io/" class="brand">Harshith</a>
    <ul class="nav-links">
      <li><a href="/harshithkantamneni.github.io/about" class:list={[{ 'is-current': current === 'about' }]}>About</a></li>
      <li><a href="/harshithkantamneni.github.io/labs" class:list={[{ 'is-current': current === 'labs' }]}>Labs</a></li>
