      <li><a href="/harshithkantamneni.github.io/notes" class:list={[{ 'is-current': current === 'notes' }]}>Notes</a></li>
      <li><a href="/harshithkantamneni.github.io/now" class:list={[{ 'is-current': current === 'now' }]}>Now</a></li>
      <li><a href="/harshithkantamneni.github.io/contact" class:list={[{ 'is-current': current === 'contact' }]}>Contact</a></li>
