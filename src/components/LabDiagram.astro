---
// LabDiagram.astro — small inline-SVG architecture diagrams for the lab pages.
// Same component renders one of four block layouts via the `kind` prop:
//   - hive-org       Director at top, six lanes radiating below
//   - hive-memory    Three stacked memory tiers
//   - agi-org        PI ↔ Director (unanimous gate), six layers below
//   - agi-memory     Three stacked memory tiers
//
// All shapes use hairlines + monospace labels via currentColor so they
// inherit the site's typography and adapt to dark/light theme tokens.

interface Props {
  kind: 'hive-org' | 'hive-memory' | 'agi-org' | 'agi-memory';
  caption?: string;
}
const { kind, caption } = Astro.props;
---

<figure class="lab-diagram">
{kind === 'hive-org' && (
  <svg viewBox="0 0 800 320" role="img" aria-labelledby="hive-org-t" preserveAspectRatio="xMidYMid meet">
    <title id="hive-org-t">HIVE org architecture — Director with six lanes</title>
    <g fill="none" stroke="currentColor" stroke-width="1">
      <rect x="280" y="20" width="240" height="60" />
      <line x1="400" y1="80" x2="400" y2="135" />
      <line x1="100" y1="135" x2="700" y2="135" />
      <line x1="100" y1="135" x2="100" y2="200" />
      <line x1="220" y1="135" x2="220" y2="200" />
      <line x1="340" y1="135" x2="340" y2="200" />
      <line x1="460" y1="135" x2="460" y2="200" />
      <line x1="580" y1="135" x2="580" y2="200" />
      <line x1="700" y1="135" x2="700" y2="200" />
      <rect x="45"  y="200" width="110" height="60" />
      <rect x="165" y="200" width="110" height="60" />
      <rect x="285" y="200" width="110" height="60" />
      <rect x="405" y="200" width="110" height="60" />
      <rect x="525" y="200" width="110" height="60" />
      <rect x="645" y="200" width="110" height="60" />
    </g>
    <g fill="currentColor" class="diag-label">
      <text x="400" y="56" text-anchor="middle">DIRECTOR</text>
      <text x="100" y="236" text-anchor="middle">ENGINEERING</text>
      <text x="220" y="236" text-anchor="middle">PRODUCT</text>
      <text x="340" y="236" text-anchor="middle">DESIGN</text>
      <text x="460" y="236" text-anchor="middle">LEGAL</text>
      <text x="580" y="236" text-anchor="middle">STRATEGY</text>
      <text x="700" y="236" text-anchor="middle">OPS</text>
    </g>
    <text x="400" y="295" text-anchor="middle" class="diag-note" fill="currentColor">
      Director pulls perspective from any lane · execution is flat
    </text>
  </svg>
)}

{kind === 'hive-memory' && (
  <svg viewBox="0 0 800 320" role="img" aria-labelledby="hive-mem-t" preserveAspectRatio="xMidYMid meet">
    <title id="hive-mem-t">HIVE memory tiers — three layers</title>
    <g fill="none" stroke="currentColor" stroke-width="1">
      <rect x="120" y="20"  width="560" height="70" />
      <rect x="120" y="100" width="560" height="70" />
      <rect x="120" y="180" width="560" height="70" stroke-dasharray="4 4" />
    </g>
    <g fill="currentColor" class="diag-label">
      <text x="160" y="50">LONG-TERM</text>
      <text x="160" y="72" class="diag-sub">ratified rules · cross-cycle knowledge</text>
      <text x="160" y="130">CYCLE</text>
      <text x="160" y="152" class="diag-sub">what is happening this run</text>
      <text x="160" y="210">CONVERSATION</text>
      <text x="160" y="232" class="diag-sub">per-turn · wiped between turns</text>
    </g>
    <text x="400" y="290" text-anchor="middle" class="diag-note" fill="currentColor">
      Conversation wipes between turns · stops one specialist's working hypothesis from polluting the next
    </text>
  </svg>
)}

{kind === 'agi-org' && (
  <svg viewBox="0 0 800 460" role="img" aria-labelledby="agi-org-t" preserveAspectRatio="xMidYMid meet">
    <title id="agi-org-t">AGI org architecture — PI and Director, six layers</title>
    <g fill="none" stroke="currentColor" stroke-width="1">
      <rect x="180" y="20" width="180" height="60" />
      <rect x="440" y="20" width="180" height="60" />
      <line x1="360" y1="50" x2="440" y2="50" stroke-dasharray="3 3" />
      <line x1="270" y1="80" x2="270" y2="120" />
      <line x1="530" y1="80" x2="530" y2="120" />
      <line x1="270" y1="120" x2="530" y2="120" />
      <line x1="400" y1="120" x2="400" y2="145" />
      <rect x="120" y="145" width="560" height="44" />
      <rect x="120" y="194" width="560" height="44" />
      <rect x="120" y="243" width="560" height="44" />
      <rect x="120" y="292" width="560" height="44" />
      <rect x="120" y="341" width="560" height="44" />
      <rect x="120" y="390" width="560" height="44" />
    </g>
    <g fill="currentColor" class="diag-label">
      <text x="270" y="56" text-anchor="middle">PI</text>
      <text x="530" y="56" text-anchor="middle">DIRECTOR</text>
      <text x="400" y="104" text-anchor="middle" class="diag-sub">unanimous-compromise gate</text>
      <text x="160" y="173">RESEARCH</text>
      <text x="500" y="173" class="diag-sub">read papers · synthesize methodology</text>
      <text x="160" y="222">ENGINEERING</text>
      <text x="500" y="222" class="diag-sub">training infrastructure</text>
      <text x="160" y="271">EVALUATION</text>
      <text x="500" y="271" class="diag-sub">benchmarks · scoring</text>
      <text x="160" y="320">QUALITY</text>
      <text x="500" y="320" class="diag-sub">independent audit of findings</text>
      <text x="160" y="369">KNOWLEDGE</text>
      <text x="500" y="369" class="diag-sub">shared memory · cross-references</text>
      <text x="160" y="418">META</text>
      <text x="500" y="418" class="diag-sub">governance · anti-forgery</text>
    </g>
  </svg>
)}

{kind === 'agi-memory' && (
  <svg viewBox="0 0 800 320" role="img" aria-labelledby="agi-mem-t" preserveAspectRatio="xMidYMid meet">
    <title id="agi-mem-t">AGI memory tiers — three layers</title>
    <g fill="none" stroke="currentColor" stroke-width="1">
      <rect x="120" y="20"  width="560" height="70" />
      <rect x="120" y="100" width="560" height="70" />
      <rect x="120" y="180" width="560" height="70" stroke-dasharray="4 4" />
    </g>
    <g fill="currentColor" class="diag-label">
      <text x="160" y="50">LONG-TERM</text>
      <text x="160" y="72" class="diag-sub">mission · governance · shared knowledge</text>
      <text x="160" y="130">LOG</text>
      <text x="160" y="152" class="diag-sub">recent decisions · rolling</text>
      <text x="160" y="210">HOT</text>
      <text x="160" y="232" class="diag-sub">active cycle state</text>
    </g>
    <text x="400" y="290" text-anchor="middle" class="diag-note" fill="currentColor">
      Bottom tier wipes each cycle · log rolls forward · top tier is the lab's accumulated ground
    </text>
  </svg>
)}

  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .lab-diagram {
    margin: var(--space-5) 0;
    padding: var(--space-4) var(--space-3);
    color: var(--ink);
    max-width: var(--grid-max);
  }

  .lab-diagram svg {
    width: 100%;
    height: auto;
    display: block;
    color: var(--ink);
  }

  /* Box labels — monospace, tracked, uppercase */
  .lab-diagram .diag-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
  }
  .lab-diagram .diag-sub {
    font-size: 10px;
    fill: var(--ink-low);
    letter-spacing: 0.04em;
    text-transform: none;
  }
  .lab-diagram .diag-note {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--ink-low);
    letter-spacing: 0.03em;
  }

  .lab-diagram figcaption {
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    color: var(--ink-low);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-align: center;
  }

  @media (max-width: 640px) {
    .lab-diagram .diag-label { font-size: 11px; }
    .lab-diagram .diag-sub   { font-size: 9px; }
  }
</style>
