---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/style.css';

interface Props {
  title: string;
  description?: string;
  current?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Autonomous AI labs running in cycles. Reports, notes, and observations from inside the systems.',
  current = '',
  ogImage = '/og-default.png',
} = Astro.props;

const siteUrl = 'https://drogon4231.github.io';
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalURL}>

  <link rel="icon" type="image/svg+xml" href="/harshithkantamneni.github.io/favicon.svg">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={new URL(ogImage, `${siteUrl}/harshithkantamneni.github.io/`).toString()}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={new URL(ogImage, `${siteUrl}/harshithkantamneni.github.io/`).toString()}>

  <!-- JSON-LD: Person schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    'name': 'Harshith Kantamneni',
    'url': `${siteUrl}/harshithkantamneni.github.io/`,
    'sameAs': [
      'https://github.com/Drogon4231',
      'https://www.linkedin.com/in/hk4231',
    ],
    'jobTitle': 'Builder of autonomous AI labs',
    'email': 'mailto:kantamneniharshith@gmail.com',
  })}></script>

  <!-- Cloudflare Web Analytics -->
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "f1ff5015a395474e96b4c7354362d1c1"}'></script>
</head>
<body>
  <Header current={current} />
  <main>
    <slot />
  </main>
  <Footer />
  <script is:inline src="/harshithkantamneni.github.io/motion.js"></script>
</body>
</html>
