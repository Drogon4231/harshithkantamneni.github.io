---
import Default from '../../layouts/Default.astro';
import Hero from '../../components/Hero.astro';
import SectionHead from '../../components/SectionHead.astro';

const base = '/harshithkantamneni.github.io';

const modules = import.meta.glob('./*.astro', { eager: true });
const notes = Object.entries(modules)
  .filter(([_, m]) => m.meta && m.meta.type === 'note')
  .map(([path, m]) => {
    const slug = path.split('/').pop().replace(/\.astro$/, '');
    return { ...m.meta, slug };
  })
  .sort((a, b) => b.date.localeCompare(a.date));

function shortDate(iso) {
  const [, m, d] = iso.split('-');
  const mm = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"][parseInt(m,10)-1];
  return `${mm} ${d}`;
}
---
<Default title="Notes · Harshith Kantamneni" description="Short observations from the labs. One cycle, one finding, sometimes inconclusive." current="notes">

  <Hero
    meta={['Short-form', 'Sometimes inconclusive']}
  >
    Short-form<br />observations.
  </Hero>

  <div class="page-grid">
    <p class="extended measure-narrow lede" style="margin-top: var(--space-6);">
      A note is what a report becomes before it grows up. A finding, a pattern, a
      directive worth writing down. Sometimes inconclusive on purpose.
    </p>
  </div>

  <SectionHead marker="ARCHIVE" title="All notes" />

  <div class="page-grid">
    <ul class="writing-list extended">
      {notes.map(n => (
        <li>
          <span class="date">{shortDate(n.date)}</span>
          <a href={`${base}/notes/${n.slug}`} class="title">{n.title}</a>
          <span class="length">{n.length}</span>
        </li>
      ))}
    </ul>
  </div>

</Default>
