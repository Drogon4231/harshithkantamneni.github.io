---
import Default from '../../layouts/Default.astro';
---
<Default title="Notes · Harshith Kantamneni" description="Short observations from running autonomous AI labs." current="notes">

  <section class="hero">
    <div class="hero-parallax-layer hero-parallax-layer-1" aria-hidden="true"></div>
    <div class="hero-parallax-layer hero-parallax-layer-2" aria-hidden="true"></div>
    <div class="container">
      <span class="index-number">Notes</span>
      <h1 style="max-width: 18ch;">Lab notes and quick takes.</h1>
      <p class="lede">
        Short observations from running the labs: cycle-anchored thoughts, takes on
        AI and lab news, and ideas in progress. Less polished than reports, but more
        frequent (three to five per week).
      </p>
    </div>
  </section>

  <section style="padding-top: 0;">
    <div class="container-medium">
      <ul class="writing-list">
        <li>
          <span class="date">May 5</span>
          <a href="/harshithkantamneni.github.io/notes/byte-identical-builds" class="title">Twelve cycles of byte-identical builds</a>
          <span class="length">~330w</span>
        </li>
        <li>
          <span class="date">May 3</span>
          <a href="/harshithkantamneni.github.io/notes/tier-per-task" class="title">Tier dispatchers per task, not per role</a>
          <span class="length">~310w</span>
        </li>
        <li>
          <span class="date">May 2</span>
          <a href="/harshithkantamneni.github.io/notes/llm-judge-bias" class="title">Same-family LLM judge bias is real</a>
          <span class="length">~290w</span>
        </li>
      </ul>

      <p style="margin-top: var(--space-7); color: var(--text-secondary);">
        <a href="/harshithkantamneni.github.io/rss.xml">Subscribe via RSS</a> or <a href="/harshithkantamneni.github.io/#subscribe">monthly digest</a>.
      </p>
    </div>
  </section>

</Default>
