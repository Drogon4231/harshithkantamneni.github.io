---
import Default from '../layouts/Default.astro';
import Hero from '../components/Hero.astro';
---
<Default title="Not Found · Harshith Kantamneni" description="The page you tried to reach does not exist." current="">

  <Hero
    meta={['Page not found']}
  >
    404.<br />Not here.
  </Hero>

  <div class="page-grid">
    <div class="extended measure-narrow lede" style="margin-top: var(--space-6);">
      <p>
        Whatever you were looking for moved, was renamed, or never existed. The
        site reorganized recently. If you arrived from a link, the link is stale.
      </p>
      <p style="margin-top: var(--space-5);">
        <a href="/harshithkantamneni.github.io/" style="font-family: var(--font-mono); font-size: var(--fs-mono); text-transform: uppercase; letter-spacing: var(--tracking-wide);">→ RETURN HOME</a>
      </p>
    </div>
  </div>

</Default>
