---
import Default from '../layouts/Default.astro';
import Hero from '../components/Hero.astro';
import SectionHead from '../components/SectionHead.astro';
import NumberedList from '../components/NumberedList.astro';

const base = '/harshithkantamneni.github.io';

// Derive the writing list from actual report + note pages. Add `export const meta`
// to any new .astro page under reports/ or notes/ and it'll auto-appear here.
const reportModules = import.meta.glob('./reports/*.astro', { eager: true });
const noteModules   = import.meta.glob('./notes/*.astro',   { eager: true });
function collectMeta(modules, baseHref) {
  const out = [];
  for (const [path, mod] of Object.entries(modules)) {
    if (!mod.meta) continue;
    const slug = path.split('/').pop().replace(/\.astro$/, '');
    if (slug === 'index') continue;
    out.push({
      ...mod.meta,
      slug,
      path: baseHref,
      displayTitle: mod.meta.listTitle || mod.meta.title,
    });
  }
  return out;
}
const writingList = [
  ...collectMeta(reportModules, `${base}/reports/`),
  ...collectMeta(noteModules,   `${base}/notes/`),
]
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 8);

function shortDate(iso) {
  const [, m, d] = iso.split('-');
  const mm = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"][parseInt(m,10)-1];
  return `${mm} ${d}`;
}

const labs = [
  {
    num: '01',
    href: `${base}/labs/hive`,
    name: 'HIVE / Product Lab',
    desc: 'A lab structured like a production company. ~46 agents play roles across engineering, product, design, legal, strategy, and ops, shipping a real privacy-first product through gated milestones. Between cycles the Director changes how the lab works, never what it builds.',
    meta: ['Active 2026', '~46 agents', 'Production-company structure'],
  },
  {
    num: '02',
    href: `${base}/labs/autonomous-research`,
    name: 'Autonomous Research Lab',
    desc: 'A research lab doing rigorous small-model ML from scratch on an 18GB MacBook. ~30 seed roles across seven layers — research, engineering, evaluation, quality, knowledge, communication, meta. No cloud compute, no frameworks. Output is publishable small-model work and envelope papers characterizing what does not fit.',
    meta: ['Active 2026', '~30 agents', 'Small-model research'],
  },
];
---
<Default title="Harshith Kantamneni" description="Autonomous AI labs running in cycles. Reports, notes, and observations from inside the systems." current="">

  <Hero
    meta={['Active 2026', 'Milwaukee, Wisconsin']}
  >
    Autonomous<br />AI labs.
  </Hero>

  <div class="page-grid">
    <p class="extended measure-narrow lede" style="margin-top: var(--space-6);">
      Multi-agent systems running in cycles. They ship things, they break things,
      they try to grade themselves. This site collects what they produce and what
      I'm learning about how they actually fail.
    </p>
    <p class="extended" style="margin-top: var(--space-4); font-family: var(--font-mono); font-size: var(--fs-mono); text-transform: uppercase; letter-spacing: var(--tracking-wide); color: var(--ink-low);">
      → START HERE: <a href={`${base}/reports/recursive-verification-surface-collapse`} style="color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--ink);">Recursive Verification-Surface Collapse</a>
    </p>
  </div>

  <SectionHead marker="LABS" title="Labs" />

  <div class="page-grid">
    <div class="extended">
      <NumberedList>
        {labs.map(lab => (
          <li>
            <span class="num">{lab.num}</span>
            <div>
              <h3><a href={lab.href}>{lab.name}</a></h3>
              <p>{lab.desc}</p>
              <p class="meta-strip">
                {lab.meta.map(m => <span>{m}</span>)}
              </p>
            </div>
            <span class="arrow" aria-hidden="true">→</span>
          </li>
        ))}
      </NumberedList>
    </div>
  </div>

  <SectionHead marker="WRITING" title="Recent" />

  <div class="page-grid">
    <ul class="writing-list extended">
      {writingList.map(w => (
        <li>
          <span class="date">{shortDate(w.date)}</span>
          <a href={`${w.path}${w.slug}`} class="title">{w.displayTitle}</a>
          <span class="length">{w.length}</span>
        </li>
      ))}
    </ul>
  </div>

  <SectionHead marker="SUBSCRIBE" title="Monthly digest" id="subscribe" />

  <div class="page-grid">
    <div class="extended">
      <div class="subscribe-block">
        <p class="meta-tag">One email per month · ~5 min read · Unsubscribe anytime</p>
        <p>The best report, a couple of notes, and what broke this cycle. Sent the first week of each month.</p>
        <form action="https://buttondown.com/api/emails/embed-subscribe/harshith" method="post" target="popupwindow" class="newsletter-form">
          <input type="email" name="email" placeholder="you@example.com" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
  </div>

</Default>
