---
import Default from '../../layouts/Default.astro';
import Hero from '../../components/Hero.astro';
import SectionHead from '../../components/SectionHead.astro';

const base = '/harshithkantamneni.github.io';

// Derive the catalog from the actual report pages — frontmatter `meta` export.
// New publishes automatically appear here as long as they include `export const meta`.
const modules = import.meta.glob('./*.astro', { eager: true });
const reports = Object.entries(modules)
  .filter(([_, m]) => m.meta && m.meta.type === 'report')
  .map(([path, m]) => {
    const slug = path.split('/').pop().replace(/\.astro$/, '');
    return { ...m.meta, slug };
  })
  .sort((a, b) => b.date.localeCompare(a.date));

function shortDate(iso) {
  const [, m, d] = iso.split('-');
  const mm = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"][parseInt(m,10)-1];
  return `${mm} ${d}`;
}
---
<Default title="Reports · Harshith Kantamneni" description="Long-form deep dives on specific failure modes from running autonomous AI labs." current="reports">

  <Hero
    meta={['About one per month']}
  >
    Long-form<br />findings.
  </Hero>

  <div class="page-grid">
    <p class="extended measure-narrow lede" style="margin-top: var(--space-6);">
      One report per month, roughly. Each one is a deep dive on a specific failure I
      hit running the labs. The situation, what broke, what worked, and what I'm
      doing about it now.
    </p>
  </div>

  <SectionHead marker="ARCHIVE" title="All reports" />

  <div class="page-grid">
    <ul class="writing-list extended">
      {reports.map(r => (
        <li>
          <span class="date">{shortDate(r.date)}</span>
          <a href={`${base}/reports/${r.slug}`} class="title">{r.title}</a>
          <span class="length">{r.length}</span>
        </li>
      ))}
    </ul>

    <p class="extended measure-tight" style="margin-top: var(--space-7); color: var(--ink-low); font-size: var(--fs-small);">
      New reports are published roughly monthly. Subscribe to the <a href={`${base}/#subscribe`}>monthly digest</a> or <a href={`${base}/rss.xml`}>RSS feed</a> to be notified.
    </p>
  </div>

</Default>
