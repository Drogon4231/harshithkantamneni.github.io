---
import Default from '../../layouts/Default.astro';
import Hero from '../../components/Hero.astro';
import SectionHead from '../../components/SectionHead.astro';
import NumberedList from '../../components/NumberedList.astro';

const base = '/harshithkantamneni.github.io';

const labs = [
  {
    num: '01',
    href: `${base}/labs/hive`,
    name: 'HIVE / Product Lab',
    desc: 'Ships iOS apps end-to-end without me in the loop. ~46 specialists across architecture, implementation, verification, and review. The Director writes meta-rules between cycles instead of telling agents what to do.',
    meta: ['Active 2026', '~46 agents', 'Phase 2'],
  },
  {
    num: '02',
    href: `${base}/labs/autonomous-research`,
    name: 'Autonomous Research Lab',
    desc: 'Three Claude opus instances reviewing each other, plus a cross-family judge for control. Studies which structural fixes actually disrupt verification-surface collapse and which are ceremonial.',
    meta: ['Active 2026', '~31–73 agents', 'Methodology'],
  },
];
---
<Default title="Labs · Harshith Kantamneni" description="Autonomous AI labs running in cycles. Each has a different goal and agent topology." current="labs">

  <Hero
    meta={['Active 2026', 'Multi-agent']}
  >
    Active<br />labs.
  </Hero>

  <div class="page-grid">
    <p class="extended measure-narrow lede" style="margin-top: var(--space-6);">
      Each lab runs on the same shape. Cycles of work, ratification gates, archived
      rejections. The goals and agent topology are different per lab. Below: what's
      currently running and where to read more on each.
    </p>
  </div>

  <SectionHead marker="ROSTER" title="Currently running" />

  <div class="page-grid">
    <div class="extended">
      <NumberedList>
        {labs.map(lab => (
          <li>
            <span class="num">{lab.num}</span>
            <div>
              <h3><a href={lab.href}>{lab.name}</a></h3>
              <p>{lab.desc}</p>
              <p class="meta-strip">
                {lab.meta.map(m => <span>{m}</span>)}
              </p>
            </div>
            <span class="arrow" aria-hidden="true">→</span>
          </li>
        ))}
      </NumberedList>
    </div>
  </div>

</Default>
