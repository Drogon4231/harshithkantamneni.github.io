---
import Default from '../layouts/Default.astro';
import Hero from '../components/Hero.astro';
import SectionHead from '../components/SectionHead.astro';
import fs from 'node:fs';
import os from 'node:os';
import path from 'node:path';

const updated = '2026-05-13';
const entries = [
  { date: 'May 2026', body: 'HIVE past cycle 99 and inside its alpha-gate run on the privacy-first product. Autonomous Research Lab mid-flight on Program 2 (dense vs MoE at sub-100M). Curator pipeline now runs the writing on this site end-to-end, with a human-in-the-loop review gate at the dashboard.' },
  { date: 'Apr 2026', body: 'Cross-lab diagnosis: HIVE PI audited Autonomous Research Lab\'s organizational rigidity from outside and prescribed five structural fixes. All five applied.' },
  { date: 'Mar 2026', body: 'Published "Recursive Verification-Surface Collapse" report. First long-form methodology piece on autonomous-lab failure modes.' },
  { date: 'Feb 2026', body: 'Both labs cleared their first methodology audit. Cycle cadence stabilized.' },
];

// Read lab_status.json from each lab if present.
function readLabStatus(filePath) {
  try {
    if (!fs.existsSync(filePath)) return null;
    return JSON.parse(fs.readFileSync(filePath, 'utf-8'));
  } catch (e) {
    return null;
  }
}

const home = os.homedir();
const hiveStatus = readLabStatus(path.join(home, 'Desktop/Fun/lab/lab_status.json'));
const agiStatus = readLabStatus(path.join(home, 'Desktop/AGI/data/lab_status.json'));

function fmtDate(iso) {
  if (!iso) return '';
  return iso.slice(0, 10);
}
---
<Default title="Now · Harshith Kantamneni" description="What I'm working on right now." current="now">

  <Hero
    meta={[`Updated ${updated}`]}
  >
    What I'm doing<br />right now.
  </Hero>

  {(hiveStatus || agiStatus) && (
    <>
      <SectionHead marker="LIVE" title="Lab status" />

      <div class="page-grid">
        <div class="extended">
          <div class="lab-status-grid">
            {hiveStatus && (
              <div class="lab-status-block">
                <p class="lab-status-name">HIVE / Product Lab</p>
                <p class="lab-status-line">cycle <strong>{hiveStatus.cycle}</strong>{hiveStatus.current_focus ? ` · ${hiveStatus.current_focus}` : ''}</p>
                {hiveStatus.last_build_status && hiveStatus.last_build_status !== 'n/a' && (
                  <p class="lab-status-meta">Last build: {hiveStatus.last_build_status} · updated {fmtDate(hiveStatus.updated_at)}</p>
                )}
              </div>
            )}
            {agiStatus && (
              <div class="lab-status-block">
                <p class="lab-status-name">Autonomous Research Lab</p>
                <p class="lab-status-line">cycle <strong>{agiStatus.cycle}</strong>{agiStatus.current_focus ? ` · ${agiStatus.current_focus}` : ''}</p>
                {agiStatus.last_build_status && agiStatus.last_build_status !== 'n/a' && (
                  <p class="lab-status-meta">Last build: {agiStatus.last_build_status} · updated {fmtDate(agiStatus.updated_at)}</p>
                )}
              </div>
            )}
          </div>
        </div>
      </div>
    </>
  )}

  <SectionHead marker="TIMELINE" title="Recent" />

  <div class="page-grid">
    <div class="extended">
      <div class="timeline">
        {entries.map(entry => (
          <>
            <p class="timeline-date">{entry.date}</p>
            <div class="timeline-entry"><p>{entry.body}</p></div>
          </>
        ))}
      </div>
    </div>
  </div>

</Default>

<style>
  .lab-status-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: var(--space-5);
    margin-bottom: var(--space-5);
  }

  .lab-status-block {
    border-top: var(--rule-thick) solid var(--rule);
    padding-top: var(--space-3);
  }

  .lab-status-name {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--ink-low);
    margin: 0 0 var(--space-2);
  }

  .lab-status-line {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-h3);
    color: var(--ink);
    margin: 0 0 var(--space-2);
  }

  .lab-status-meta {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--ink-low);
    margin: 0;
  }
</style>
